{
  "name": "tictactoe",
  "version": "1.0.3",
  "description": "a tictactoe game",
  "license": "GPL-3.0-or-later",
  "main": "dist/tictactoe.min.js",
  "types": "tictactoe.d.ts",
  "exports": {
    ".": "./dist/tictactoe.js",
    "./assets/*": "./assets/*",
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "scripts": {
    "prepare": "$npm_execpath run compile",
    "compile": "tsc --sourceMap --declaration",
    "lint": "eslint src/*.ts",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "bundle": "esbuild src/main.ts --bundle --format=esm --outfile=dist/tictactoe.min.js --minify",
    "dev": "esbuild src/main.ts --bundle --format=esm --outfile=dist/tictactoe.min.js --minify --watch",
    "dist": "$npm_execpath run compile && $npm_execpath run bundle",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "gh-pages -d dist"
  },
  "files": [
    "/dist/*",
    "/dist/*.js",
    "/dist/*.d.ts",
    "/dist/*.js.map",
    "/assets/*.css"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {},
  "publishConfig": {
    "registry": "http://localhost:4873"
  }
}
